ARG SGLANG_BASE_IMAGE=lmsysorg/sglang:latest-runtime
FROM ${SGLANG_BASE_IMAGE}

ENV TRANSFORMERS_OFFLINE=1 \
    HF_HUB_OFFLINE=1 \
    HF_DATASETS_OFFLINE=1 \
    PYTHONUNBUFFERED=1 \
    RYV_SGLANG_PAGE_SIZE=1 \
    RYV_TRUST_REMOTE_CODE=0 \
    RYV_EAGER_LOAD_SGLANG=1 \
    RYV_SGLANG_VERIFY_MAX_NEW_TOKENS=0

COPY run.py /app/run.py
WORKDIR /work
ENTRYPOINT ["python3", "-u", "/app/run.py"]
